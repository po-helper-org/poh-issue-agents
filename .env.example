# --- GitHub App ---
# Регистрируется на github.com/settings/apps (или org-level apps для MTS).
# Permissions: Issues (read/write), Pull requests (read/write), Contents (read/write).
# Webhook events: Issues, Issue comments.
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=/app/secrets/github-app-private-key.pem
GITHUB_WEBHOOK_SECRET=change-me
# Installation ID — после установки App на репозиторий, видно в URL установки.
GITHUB_INSTALLATION_ID=
GITHUB_REPOSITORY=your-org/your-repo

# --- GLM через z.ai ---
# OpenAI-совместимый эндпоинт — используется Python-стадиями (gate/classify/
# duplicate/priority) через Instructor.
ZAI_BASE_URL=https://api.z.ai/api/openai/v1
ZAI_API_KEY=

# Anthropic-совместимый эндпоинт — используется claude -p для po-helper/
# SA-helper skills (сами скиллы не меняются, меняется только backend).
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_AUTH_TOKEN=

# --- Модели ---
MODEL_GATE=glm-4.5-air
MODEL_CLASSIFY=glm-5.2

# --- Внешние инструменты ---
# TODO: способ установки/аутентификации deb8flow — подставь свой.
DEB8FLOW_BIN=deb8flow
