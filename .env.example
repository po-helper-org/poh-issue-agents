# --- Режим безопасности ---
# DRY_RUN=1 — ни одной мутации в GitHub: комментарии, лейблы и реакции только
# пишутся в лог. Пустое значение = боевой режим. Держи 1 до первого удачного
# прогона.
DRY_RUN=1

# --- Аутентификация в GitHub: PAT или App ---
# Достаточно одного из двух путей. PAT проще: github_client предпочитает его,
# если он задан, и тогда блок GitHub App ниже можно оставить пустым.
# Права токена: repo (плюс admin:repo_hook, если заводишь вебхук через gh api).
GH_TOKEN=

# --- GitHub App ---
# Регистрируется на github.com/settings/apps (или org-level apps для MTS).
# Permissions: Issues (read/write), Pull requests (read/write), Contents (read/write).
# Webhook events: Issues, Issue comments.
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=/app/secrets/github-app-private-key.pem
GITHUB_WEBHOOK_SECRET=change-me
# Installation ID — после установки App на репозиторий, видно в URL установки.
GITHUB_INSTALLATION_ID=
GITHUB_REPOSITORY=your-org/your-repo

# --- GLM через z.ai ---
# Один провайдер (z.ai), одна модель (GLM). Две пары переменных ниже — не два
# провайдера, а два формата API одного и того же z.ai.

# OpenAI-совместимый эндпоинт — используется всеми Python-стадиями
# (gate/classify/duplicate/priority/estimate) через Instructor. Обязателен.
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_API_KEY=

# Anthropic-совместимый эндпоинт того же z.ai — нужен ТОЛЬКО пайплайнам
# research/bug (запускают CLI claude -p, который говорит по протоколу
# Anthropic). Эти пайплайны сейчас NotImplementedError, поэтому для триажа
# и для /estimate обе переменные не используются — можно оставить пустыми.
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_AUTH_TOKEN=

# --- Модели ---
MODEL_GATE=glm-4.5-air
MODEL_CLASSIFY=glm-4.6

# --- Внешние инструменты ---
# TODO: способ установки/аутентификации deb8flow — подставь свой.
DEB8FLOW_BIN=deb8flow

# --- Только для docker-compose.dokploy.yml (self-hosted развёртывание) ---
# Локальный docker-compose.yml использует захардкоженный пароль, потому что
# Postgres там не опубликован наружу. В продакшн-варианте пароль обязателен —
# деплой упадёт, если переменная пуста. Сгенерируй: openssl rand -hex 24
POSTGRES_PASSWORD=
